{
  "id": "xiaozhi",
  "name": "Xiaozhi Integration",
  "description": "WebSocket client for xiaozhi-esp32-server bidirectional communication",
  "version": "1.0.2",
  "extensions": ["./dist/index.js"],
  "configSchema": {
    "type": "object",
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "WebSocket adapter URL (e.g., ws://your-server:8080/ws)",
        "default": "ws://localhost:8080/ws"
      },
      "authToken": {
        "type": "string",
        "description": "Optional authentication token"
      },
      "reconnectInterval": {
        "type": "number",
        "description": "Time between reconnection attempts (ms)"
      },
      "maxReconnectAttempts": {
        "type": "number",
        "description": "Maximum number of reconnection attempts"
      },
      "heartbeatInterval": {
        "type": "number",
        "description": "Heartbeat/ping interval (ms)"
      }
    },
    "required": []
  },
  "config": {
    "uiHints": {
      "serverUrl": {
        "label": "Server URL",
        "help": "WebSocket adapter URL (e.g., ws://your-server:8080/ws)",
        "placeholder": "ws://localhost:8080/ws"
      },
      "authToken": {
        "label": "Auth Token",
        "help": "Optional authentication token (must match adapter authToken config)",
        "sensitive": true
      },
      "reconnectInterval": {
        "label": "Reconnect Interval (ms)",
        "help": "Time between reconnection attempts",
        "advanced": true
      },
      "maxReconnectAttempts": {
        "label": "Max Reconnect Attempts",
        "help": "Maximum number of reconnection attempts before giving up",
        "advanced": true
      },
      "heartbeatInterval": {
        "label": "Heartbeat Interval (ms)",
        "help": "Heartbeat/ping interval",
        "advanced": true
      }
    }
  }
}
